script/source = "extends Control

@export var health: int = 100
@export var speed: float = 250.5
@export var player_name: String = \"Test Interface\"
@export var is_active: bool = true
@export var spawn_point: Vector2 = Vector2(120, 80)
@export var play_area: Rect2 = Rect2(0, 0, 1152, 648)
@export var tint_color: Color = Color(0.25, 0.55, 0.95, 1.0)
@export var target_path: NodePath = NodePath(\"MarginContainer/MainVBox/ToolBar/Button\")
@export var tags: Array[String] = [\"ui\", \"stress-test\", \"repair\"]
@export var settings: Dictionary = {\"volume\": 0.8, \"difficulty\": 2}
@export_enum(\"Easy\", \"Normal\", \"Hard\") var difficulty: String = \"Normal\"

func _ready() -> void:
	pass
"

